<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO" shutdownHook="disable">
    <Appenders>
        <Console name="ConsoleNormal" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>
                    %d{HH:mm:ss.SSS} %highlight{%-5level}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} [%t] - %msg%n
                </Pattern>
            </PatternLayout>
        </Console>

        <Console name="ConsoleClean" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>
                    %d{HH:mm:ss.SSS} %highlight{%-5level}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} %msg%n
                </Pattern>
            </PatternLayout>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="maven" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleClean"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="ConsoleNormal"/>
        </Root>
    </Loggers>
</Configuration>